#include <stdio.h>
#include <stdlib.h>
typedef struct No {
    int valor;
    struct No* prox;
}No;

void inserir_inicio(No** head, int v) { /// pont de pont para inserir valor nela
    No* novoElemento = malloc(sizeof(No));
    if (novoElemento == NULL) return;
    novoElemento->valor = v;
    novoElemento->prox = *head;
    *head = novoElemento;
}

void imprimir(No* head) {
    No* p = head;
    while (p != NULL) {
        printf("[%d] ->", p->valor);
        p = p->prox;
    }
}

